# Environment variables for the Network Anomaly Detection project
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# GenAI Analyst explanations (Step 9 — Optional)
# Two backends supported — set ONE of the following:

# Option A: Local LLM server (no API key required)
# Works with Ollama, LM Studio, or llama.cpp server.
#   Ollama setup:    ollama pull llama3.2 && ollama serve
#   LM Studio setup: enable Local Server in the app (port 1234)
LOCAL_LLM_URL=http://localhost:9090/v1
LOCAL_LLM_MODEL=llama3.2

# Option B: OpenAI API
# Obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
