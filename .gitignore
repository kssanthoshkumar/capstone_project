# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data (large files — download via data_loader.py auto_download=True)
data/raw/*.txt
data/raw/*.csv
data/processed/*.npy

# Models (large binary artefacts — regenerate via train_and_save.py)
models/*.pkl
models/*.keras

# Keep placeholder and config files
!models/.gitkeep
!models/configs.yaml
!models/autoencoder_threshold.json
!data/raw/.gitkeep
!data/processed/.gitkeep

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Secrets
.env
*.key
*.pem

# Generator scripts (internal tooling, not needed for reproducibility)
presentations/**/generate_ppt.py
generate_architecture_diagram.py
reports/generate_docx.py

# Temporary / cache
*.tmp
*.bak
